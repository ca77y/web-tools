{
  "name": "@web-tools/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "web-tools": "dist/index.js"
  },
  "scripts": {
    "start": "tsx --env-file=../../.env.local src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "tsc && API_KEY=test-key SEARXNG_ENGINES= node --test dist/*.test.js"
  },
  "dependencies": {
    "@web-tools/toolkit": "workspace:*",
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
