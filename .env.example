# Server Authentication (required)
# Auto-generated on Railway deploy; set manually for local development.
API_KEY=your-api-key

# SearXNG Configuration
SEARXNG_URL=http://searxng:8080   # SearXNG instance URL (default: http://searxng.railway.internal:8080)
SEARXNG_ENGINES=                  # Optional: Comma-separated engines (e.g. "google,brave,duckduckgo")
SEARXNG_CATEGORIES=               # Optional: Comma-separated categories (e.g. "general,science")

# Crawl4AI Configuration
CRAWL4AI_URL=http://crawl4ai:11235  # Crawl4AI instance URL (default: http://crawl4ai.railway.internal:11235)
# CRAWL4AI_API_TOKEN=               # Optional: API token for Crawl4AI authentication

# Proxy Configuration (optional, but REQUIRED for reliable Google search)
# Routes SearXNG's outgoing engine requests through a residential proxy.
# Without it, Google rate-limits the datacenter IP under load.
#
# Evomi: append targeting params to the PASSWORD (not the username), and you
# MUST geo-target US — the EU residential pool is broadly /sorry/-blocked by
# Google; US IPs are mostly clean. Keep it ROTATING (no _session-…) so each
# retry gets a fresh IP (a sticky IP that lands on a burned one stays burned).
# PROXY_URL=http://user:PASS_country-US@core-residential.evomi.com:1000
